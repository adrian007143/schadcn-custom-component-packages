# Override this with your public domain before a production deploy.
# Example: REGISTRY_BASE_URL=https://formkitcn.pro
# Coolify: add this in Environment Variables and keep `Build Variable` enabled.
REGISTRY_BASE_URL=http://localhost:3000

# Optional public site URL for metadata/client helpers.
# Coolify example: NEXT_PUBLIC_SITE_URL=$COOLIFY_URL
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_COMPONENT_REGISTRY_URL=

# Google reCAPTCHA keys
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
